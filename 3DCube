#include <GL/glut.h>

float rotX = 0, rotY = 0;

void drawCube() {
    glBegin(GL_QUADS);

    glColor3f(1,0,0); // Front
    glVertex3f(-0.5,-0.5,0.5); glVertex3f(0.5,-0.5,0.5);
    glVertex3f(0.5,0.5,0.5);   glVertex3f(-0.5,0.5,0.5);

    glColor3f(0,1,0); // Back
    glVertex3f(-0.5,-0.5,-0.5); glVertex3f(-0.5,0.5,-0.5);
    glVertex3f(0.5,0.5,-0.5);   glVertex3f(0.5,-0.5,-0.5);

    glColor3f(0,0,1); // Left
    glVertex3f(-0.5,-0.5,-0.5); glVertex3f(-0.5,-0.5,0.5);
    glVertex3f(-0.5,0.5,0.5);   glVertex3f(-0.5,0.5,-0.5);

    glColor3f(1,1,0); // Right
    glVertex3f(0.5,-0.5,-0.5); glVertex3f(0.5,0.5,-0.5);
    glVertex3f(0.5,0.5,0.5);   glVertex3f(0.5,-0.5,0.5);

    glColor3f(0,1,1); // Top
    glVertex3f(-0.5,0.5,-0.5); glVertex3f(-0.5,0.5,0.5);
    glVertex3f(0.5,0.5,0.5);   glVertex3f(0.5,0.5,-0.5);

    glColor3f(1,0,1); // Bottom
    glVertex3f(-0.5,-0.5,-0.5); glVertex3f(0.5,-0.5,-0.5);
    glVertex3f(0.5,-0.5,0.5);   glVertex3f(-0.5,-0.5,0.5);

    glEnd();
}

void display() {
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);
    glLoadIdentity();
    glRotatef(rotX,1,0,0);
    glRotatef(rotY,0,1,0);
    drawCube();
    glutSwapBuffers();
}

void specialKeys(int key,int x,int y) {
    if(key==GLUT_KEY_UP) rotX+=5;
    if(key==GLUT_KEY_DOWN) rotX-=5;
    if(key==GLUT_KEY_LEFT) rotY-=5;
    if(key==GLUT_KEY_RIGHT) rotY+=5;
    glutPostRedisplay();
}

int main(int argc,char** argv) {
    glutInit(&argc,argv);
    glutInitDisplayMode(GLUT_DOUBLE|GLUT_RGB|GLUT_DEPTH);
    glutInitWindowSize(600,600);
    glutCreateWindow("3D Cube Rotation");
    glEnable(GL_DEPTH_TEST);
    glutDisplayFunc(display);
    glutSpecialFunc(specialKeys);
    glutMainLoop();
    return 0;
}
