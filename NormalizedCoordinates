#include <iostream>
#include <graphics.h>
using namespace std;

// Map normalized coordinates (-1 to +1) to screen pixels
int mapX(float x, int maxX) {
    return (int)((x + 1) * (maxX / 2));
}
int mapY(float y, int maxY) {
    return (int)((1 - y) * (maxY / 2)); // invert Y for graphics.h
}

int main() {
    int gd = DETECT, gm;
    initgraph(&gd, &gm, "");

    int maxX = getmaxx();
    int maxY = getmaxy();

    // Original triangle vertices in normalized coordinates
    float x1 = -0.5, y1 = -0.5;
    float x2 =  0.5, y2 = -0.5;
    float x3 =  0.0, y3 =  0.5;

    // Map to screen coordinates
    int X1 = mapX(x1, maxX), Y1 = mapY(y1, maxY);
    int X2 = mapX(x2, maxX), Y2 = mapY(y2, maxY);
    int X3 = mapX(x3, maxX), Y3 = mapY(y3, maxY);

    // Draw original triangle (RED)
    setcolor(RED);
    line(X1, Y1, X2, Y2);
    line(X2, Y2, X3, Y3);
    line(X3, Y3, X1, Y1);

    // Translation values
    float tx, ty;
    cout << "Enter translation values (tx ty): ";
    cin >> tx >> ty;

    // Translate vertices
    int XT1 = mapX(x1 + tx, maxX), YT1 = mapY(y1 + ty, maxY);
    int XT2 = mapX(x2 + tx, maxX), YT2 = mapY(y2 + ty, maxY);
    int XT3 = mapX(x3 + tx, maxX), YT3 = mapY(y3 + ty, maxY);

    // Draw translated triangle (GREEN)
    setcolor(GREEN);
    line(XT1, YT1, XT2, YT2);
    line(XT2, YT2, XT3, YT3);
    line(XT3, YT3, XT1, YT1);

    getch();
    closegraph();
    return 0;
}
